# Gemini API key (required by agent/server.py)
GEMINI_API_KEY=your-gemini-key-here

# Comma-separated list of allowed CORS origins for the FastAPI backend.
# In dev, http://localhost:5173 is enough.
# In prod (HF Space), set this to your Vercel URL, e.g.:
#   ALLOWED_ORIGINS=https://enviroskin.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Optional frontend override for the Express API base in production.
# Example: VITE_API_BASE_URL=https://enviroskin.onrender.com
VITE_API_BASE_URL=

# Optional frontend override for the FastAPI analysis base in production.
# Example: VITE_ANALYZE_API_BASE_URL=https://your-fastapi-service.example.com
VITE_ANALYZE_API_BASE_URL=
